// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/docker-existing-dockerfile
// GG for examples https://github.com/devcontainers/template-starter/
{
	"name": "Existing Dockerfile",
	"build": {
		// Sets the run context to one level up instead of the .devcontainer folder.
		"context": "..",
		// Update the 'dockerFile' property if you aren't using the standard 'Dockerfile' filename.
		"dockerfile": "../Dockerfile",
		"args":{
			"TAKE_PROJECT_NAME":"${localWorkspaceFolderBasename}",
			"DEV_UID":"${localEnv:UID}",
			"DEV_GID":"${localEnv:GID}"
		}
	},
	"features": {
		// GG eval https://github.com/devcontainers/features/tree/main/src/node
		// if you want a simpler way to install node
		// "ghcr.io/devcontainers/features/python:1": {}
		//,"ghcr.io/devcontainer-config/features/dot-config:4": {}
	},
	// Share copilot auth
	"mounts": [                                                                                                                                            
	{                                                                                                                                                    
		"source": "${localEnv:HOME}/.copilot",                                                                                                                
		"target": "/home/devcontainer/.copilot",                                                                                                                
		"type": "bind"                                                                                                                                     
	}
	,{                                                                                                                                                    
		"source": "${localEnv:HOME}/.claude",                                                                                                                
		"target": "/home/devcontainer/.claude",                                                                                                                
		"type": "bind"                                                                                                                                     
	}
	,{                                                                                                                                                    
		"source": "${localEnv:HOME}/.claude.json",                                                                                                                
		"target": "/home/devcontainer/.claude.json",                                                                                                                
		"type": "bind"                                                                                                                                     
	}    
],

	// See https://code.visualstudio.com/remote/advancedcontainers/environment-variables
	"runArgs": ["--env-file",".devcontainer/devcontainer.env"]

	// Features to add to the dev container. More info: https://containers.dev/features.
	// "features": {},

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],

	// Uncomment the next line to run commands after the container is created.
	// "postCreateCommand": "cat /etc/os-release",

	// Configure tool-specific properties.
	// "customizations": {},

	// Connect as non-root user for stronger security. More info: https://aka.ms/dev-containers-non-root.
	,
	"remoteUser": "devcontainer",

	"customizations": {
		"vscode": {
			"extensions": [
				"TakumiI.markdowntable"
			]
		}
	}
}
